  "notes": "San Francisco has one of the most comprehensive recycling programs in the US with three streams: Blue (recycling), Green (compost/organics), and Black (garbage). SF aims for zero waste. Composting is mandatory for all residents and businesses.",
  "rules": {
    "recycling": [
      "aluminum can",
      "steel and tin can",
      "glass bottle and jar",
      "plastic bottle (#1 PET, #2 HDPE)",
      "plastic jug",
      "cardboard",
      "corrugated cardboard",
      "newspaper and magazines",
      "office paper and mail",
      "paper bags",
      "milk and juice cartons",
      "Tetra Pak",
      "aluminum foil (clean, balled up)",
      "plastic tub (#1-#7 rigid containers)",
      "plastic clam shell (clear rigid, clean)",
      "shampoo and soap bottles",
      "laundry detergent bottles",
      "empty aerosol cans",
      "books (hardcover and paperback)",
      "envelopes (including with windows)"
    ],
    "garbage": [
      "black plastic bag",
      "plastic film and wrap",
      "bubble wrap",
      "styrofoam (EPS foam)",
      "chip bags and candy wrappers",
      "coffee cups with plastic liner",
      "plastic straws and utensils (unless certified compostable)",
      "soiled paper not suitable for compost",
      "broken glass (wrapped safely)",
      "ceramics and dishware",
      "tissues and facial wipes",
      "diapers",
      "rubber bands",
      "polystyrene packaging peanuts",
      "wax-coated cardboard",
      "mirrors",
      "clothing and textiles (donate instead if usable)"
    ],
    "compost": [
      "all food scraps and leftovers",
      "fruit and vegetables",
      "meat, fish and poultry",
      "dairy and eggs",
      "coffee grounds and paper filters",
      "tea bags",
      "bread, pasta, grains, and rice",
      "soiled paper napkins and towels",
      "soiled pizza boxes",
      "wax paper",
      "certified compostable cups, plates, and utensils",
      "certified compostable plastic bags",
      "wooden chopsticks and popsicle sticks",
      "flowers and plants",
      "grass clippings and leaves",
      "dog and cat waste (in green bin, no plastic bags)",
      "hair and nail clippings"
    ],
    "depot": [
      "hazardous household waste",
      "paint and varnishes",
      "all batteries",
      "electronics and e-waste",
      "light bulbs (CFL, fluorescent)",
      "motor oil and automotive fluids",
      "propane tanks",
      "medications",
      "syringes and sharps (in Sharps container)",
      "pesticides and fertilizers",
      "cleaning chemicals",
      "pool chemicals",
      "fire extinguishers",
      "mercury-containing devices"
    ],
    "bulk": [
      "furniture",
      "mattress and box spring",
      "large appliances (refrigerator, washer, dryer)",
      "bicycle",
      "exercise equipment",
      "carpets and rugs",
      "large electronics (TV, monitor)"
    ]
  }
