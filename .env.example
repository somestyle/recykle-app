# ─── Recykle Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Required: Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override the Gemini model (default: gemini-2.0-flash-live-001)
# GEMINI_MODEL=gemini-2.0-flash-live-001

# Optional: Server port (default: 3000 for dev, 8080 for Cloud Run)
# PORT=3000
